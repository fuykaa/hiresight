# ============================================================
# HireSight — Template Environment Variables
# Salin file ini menjadi .env lalu isi nilainya
# cp .env.example .env
# ============================================================

# --- Database PostgreSQL ---
DB_USER=postgres
DB_PASSWORD=isi_password_kuat_di_sini
DB_NAME=hiresight_db
# Untuk dev lokal (tanpa Docker full): DB_HOST=localhost, DB_PORT=5432
# Untuk Docker (docker-compose.yml): DB_HOST sudah di-set otomatis ke "db"
DB_HOST=localhost
DB_PORT=5432

# --- JWT Secret ---
# Isi dengan string random panjang. Generate: openssl rand -hex 32
JWT_SECRET=

# --- Groq API Key ---
# Daftar gratis di https://console.groq.com → Create API Key
GROQ_API_KEY=

# --- CORS & URL Config ---
# Dev lokal:
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8081

# VPS / Production (ganti IP_VPS dengan IP address VPS kamu):
# CORS_ORIGIN=http://IP_VPS:3000
# NEXT_PUBLIC_API_URL=http://IP_VPS:8081
